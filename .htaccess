Options -Indexes

# ── URL routing ───────────────────────────────────────────────
RewriteEngine On
RewriteBase /

# Block access to .git and other dot-files (except .well-known)
RewriteRule ^\.git(/.*)?$ - [F,L]
RewriteRule ^\.(?!well-known) - [F,L]

# Allow direct access to assets and well-known paths
RewriteCond %{REQUEST_URI} ^/(assets|sw\.js|manifest\.json|favicon)
RewriteRule ^ - [L]

# Skip if file or directory actually exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to front controller
RewriteRule ^ index.php [L]

# ── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ── Static asset caching ──────────────────────────────────────
<FilesMatch "\.(css|js|png|jpg|webp|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Service worker must never be cached by the browser
<FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# ── Deny direct access to PHP config files ───────────────────
<FilesMatch "^config\.local\.php$">
    Require all denied
</FilesMatch>
